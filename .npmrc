# Supply-chain hardening.
#
# Block all lifecycle scripts (preinstall, install, postinstall, prepare)
# from running during `pnpm install`. Primary defense against the npm
# postinstall-worm class — worms that propagate by hiding code in
# lifecycle scripts of compromised packages (e.g. the 2025 Shai-Hulud
# campaigns affecting TanStack and others).
#
# Refs:
#   https://socket.dev/blog/tanstack-npm-packages-compromised-mini-shai-hulud-supply-chain-attack
#   https://tanstack.com/blog/npm-supply-chain-compromise-postmortem
#
# Side-effect: the root project's own `prepare` script (husky install)
# also will not run automatically. After cloning, contributors must run
# `pnpm prepare` once to set up git hooks. CI re-enables scripts only
# inside trusted publish steps.
ignore-scripts=true

# Pin registry. Refuse implicit registry redirects.
registry=https://registry.npmjs.org/

# Surface audit results on install. Fail level handled in CI separately.
audit-level=moderate

# Reduce noise / telemetry surface.
fund=false
update-notifier=false
