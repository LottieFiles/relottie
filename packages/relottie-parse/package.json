{
  "name": "@lottiefiles/relottie-parse",
  "version": "1.15.0",
  "type": "module",
  "description": "Parse Lottie JSON format to LAST",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LottieFiles/relottie.git",
    "directory": "packages/relottie-parse"
  },
  "homepage": "https://github.com/LottieFiles/relottie#readme",
  "bugs": "https://github.com/LottieFiles/relottie/issues",
  "author": "LottieFiles",
  "contributors": [
    "Aidos Sabit <https://github.com/aidosmf>"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9.5.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*",
        "dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "unified",
    "relottie",
    "relottie-plugin",
    "plugin",
    "lottie",
    "dotlottie",
    "last",
    "lottie-ast",
    "abstract",
    "syntax",
    "tree",
    "ast",
    "serialize",
    "compile"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint --fix .",
    "stats:eslint": "cross-env TIMING=1 eslint .",
    "stats:ts": "tsc -p tsconfig.build.json --extendedDiagnostics",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest",
    "test:coverage": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@humanwhocodes/momoa": "3.3.10",
    "@lottiefiles/last": "workspace:*",
    "@lottiefiles/last-builder": "workspace:*",
    "unist-util-is": "6.0.1"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@lottie-animation-community/lottie-types": "1.2.0",
    "@lottiefiles/jest-config": "1.0.0",
    "@types/jest": "30.0.0",
    "@types/jest-specific-snapshot": "0.5.6",
    "@types/node": "25.9.0",
    "@types/unist": "3.0.3",
    "esbuild": "0.28.1",
    "jest": "30.4.2",
    "jest-specific-snapshot": "8.0.0",
    "ts-jest": "29.4.10",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "unified": "11.0.5",
    "vfile": "6.0.3",
    "vfile-reporter": "8.1.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
